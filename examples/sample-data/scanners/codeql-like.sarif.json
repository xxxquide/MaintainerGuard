{
  "version": "2.1.0",
  "$schema": "https://json.schemastore.org/sarif-2.1.0.json",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeQL",
          "rules": [
            {
              "id": "py/path-injection",
              "shortDescription": {
                "text": "User-controlled path reaches file operation"
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "properties": {
                "tags": ["security", "external/cwe/cwe-022"]
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "py/path-injection",
          "message": {
            "text": "User-controlled path may reach a file operation."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/files.py"
                },
                "region": {
                  "startLine": 57
                }
              }
            }
          ]
        }
      ]
    }
  ]
}
